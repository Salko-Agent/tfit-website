# FlexFit Website Configuration Template
# Copy this to .env and adjust variables as needed

# Secret API key used for communication between Zentra CMS and this website
ZENTRA_API_KEY=your_zentra_api_key_here

# Public base URL for uploads
UPLOAD_URL=https://demo.flexfit-demo.at/assets/uploads/

# BCrypt hash for BMS Hub admin panel
# Generate a new hash using: php -r "echo password_hash('YourNewPassword', PASSWORD_BCRYPT);"
# Default hash below corresponds to password "yourpassword"
BMS_ADMIN_HASH=$2y$12$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uXhHJC0OS
